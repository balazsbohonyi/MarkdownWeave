{
  "name": "markdownweave",
  "displayName": "MarkdownWeave",
  "description": "Obsidian-style inline WYSIWYG editing for Markdown files",
  "version": "1.0.0-beta.1",
  "publisher": "markdownweave",
  "repository": {
    "type": "git",
    "url": "https://github.com/balazsbohonyi/MarkdownWeave.git"
  },
  "license": "MIT",
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [],
  "main": "./dist/extension.js",
  "contributes": {
    "customEditors": [
      {
        "viewType": "markdownWeave.editor",
        "displayName": "Markdown Weave",
        "selector": [
          {
            "filenamePattern": "*.md"
          },
          {
            "filenamePattern": "*.markdown"
          }
        ],
        "priority": "option"
      }
    ],
    "commands": [
      {
        "command": "markdownWeave.openEditor",
        "title": "Open with Markdown Weave",
        "category": "Markdown Weave"
      },
      {
        "command": "markdownWeave.toggleBold",
        "title": "Toggle Bold",
        "category": "Markdown Weave"
      },
      {
        "command": "markdownWeave.toggleItalic",
        "title": "Toggle Italic",
        "category": "Markdown Weave"
      },
      {
        "command": "markdownWeave.toggleStrikethrough",
        "title": "Toggle Strikethrough",
        "category": "Markdown Weave"
      },
      {
        "command": "markdownWeave.toggleInlineCode",
        "title": "Toggle Inline Code",
        "category": "Markdown Weave"
      },
      {
        "command": "markdownWeave.insertLink",
        "title": "Insert Link",
        "category": "Markdown Weave"
      },
      {
        "command": "markdownWeave.toggleCodeBlock",
        "title": "Toggle Code Block",
        "category": "Markdown Weave"
      },
      {
        "command": "markdownWeave.increaseHeading",
        "title": "Increase Heading Level",
        "category": "Markdown Weave"
      },
      {
        "command": "markdownWeave.decreaseHeading",
        "title": "Decrease Heading Level",
        "category": "Markdown Weave"
      }
    ],
    "keybindings": [
      {
        "command": "markdownWeave.toggleBold",
        "key": "ctrl+b",
        "mac": "cmd+b",
        "when": "activeCustomEditorId == 'markdownWeave.editor'"
      },
      {
        "command": "markdownWeave.toggleItalic",
        "key": "ctrl+i",
        "mac": "cmd+i",
        "when": "activeCustomEditorId == 'markdownWeave.editor'"
      },
      {
        "command": "markdownWeave.toggleStrikethrough",
        "key": "ctrl+shift+x",
        "mac": "cmd+shift+x",
        "when": "activeCustomEditorId == 'markdownWeave.editor'"
      },
      {
        "command": "markdownWeave.toggleInlineCode",
        "key": "ctrl+shift+`",
        "mac": "cmd+shift+`",
        "when": "activeCustomEditorId == 'markdownWeave.editor'"
      },
      {
        "command": "markdownWeave.insertLink",
        "key": "ctrl+k",
        "mac": "cmd+k",
        "when": "activeCustomEditorId == 'markdownWeave.editor'"
      },
      {
        "command": "markdownWeave.toggleCodeBlock",
        "key": "ctrl+shift+c",
        "mac": "cmd+shift+c",
        "when": "activeCustomEditorId == 'markdownWeave.editor'"
      },
      {
        "command": "markdownWeave.increaseHeading",
        "key": "ctrl+shift+]",
        "mac": "cmd+shift+]",
        "when": "activeCustomEditorId == 'markdownWeave.editor'"
      },
      {
        "command": "markdownWeave.decreaseHeading",
        "key": "ctrl+shift+[",
        "mac": "cmd+shift+[",
        "when": "activeCustomEditorId == 'markdownWeave.editor'"
      }
    ],
    "configuration": {
      "title": "Markdown Weave",
      "properties": {
        "markdownWeave.pasteImageFolder": {
          "type": "string",
          "default": "",
          "description": "Folder for pasted images, relative to the document file. Leave empty to save in the document's directory."
        }
      }
    },
    "menus": {
      "explorer/context": [
        {
          "command": "markdownWeave.openEditor",
          "when": "resourceExtname =~ /\\.(md|markdown)$/",
          "group": "navigation"
        }
      ]
    }
  },
  "scripts": {
    "compile": "node esbuild.mjs",
    "watch": "node esbuild.mjs --watch",
    "package": "node esbuild.mjs --production",
    "check-types": "tsc -p ./ --noEmit",
    "lint": "eslint ."
  },
  "dependencies": {
    "@codemirror/commands": "^6.10.3",
    "@codemirror/lang-markdown": "^6.5.0",
    "@codemirror/language": "^6.12.3",
    "@codemirror/state": "^6.6.0",
    "@codemirror/view": "^6.41.1",
    "@lezer/markdown": "^1.6.3",
    "@shikijs/transformers": "^4.0.2",
    "dompurify": "^3.4.1",
    "katex": "^0.16.45",
    "mermaid": "^11.14.0",
    "shiki": "^4.0.2"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@types/vscode": "^1.116.0",
    "@typescript-eslint/eslint-plugin": "^8.59.0",
    "@typescript-eslint/parser": "^8.59.0",
    "esbuild": "^0.28.0",
    "eslint": "^10.2.1",
    "typescript": "^6.0.3"
  }
}
